@page "/empresas"
@using AppFE.Shared
@inject HttpClient Http

<PageTitle>Listado de Empresas</PageTitle>

<div class="container mt-4">
    <h2>Empresas</h2>

    <button class="btn btn-primary mb-3" @onclick="LoadEmpresas">Cargar Empresas</button>

    @if (empresas == null)
    {
        <p><em>Cargando datos desde Azure...</em></p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>CIF</th>
                    <th>Nombre</th>
                    <th>Localidad</th>
                    <th>Plazas</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in empresas)
                {
                    <tr>
                        <td>@emp.cif</td>
                        <td>@emp.nombre</td>
                        <td>@emp.localidad</td>
                        <td>@emp.plazas_ofertadas</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<Empresa>? empresas;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmpresas();
    }

    private async Task LoadEmpresas()
    {
        try 
        {
            // ASWA enruta mágicamente "/api/..." a tu proyecto de Azure Functions
            empresas = await Http.GetFromJsonAsync<List<Empresa>>("/api/empresas");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error de conexión: {ex.Message}");
        }
    }
}